# Google API key for maps/places
EXPO_PUBLIC_GOOGLE_API_KEY=your_google_api_key_here

# Google Calendar ID for event syncing
EXPO_PUBLIC_GOOGLE_CALENDAR_ID=your_google_calendar_id_here

# URL to the camps XLSX spreadsheet
EXPO_PUBLIC_CAMPS_XLSX_URL=your_camps_xlsx_url_here

# Optional: pin Metro/dev-client to loopback for the iOS simulator.
# Comment out when testing on a physical device over Wi-Fi.
# REACT_NATIVE_PACKAGER_HOSTNAME=localhost
